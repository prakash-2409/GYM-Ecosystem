# === Database ===
DATABASE_URL=postgresql://gymstack:gymstack@localhost:5432/gymstack

# === JWT ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# === Razorpay ===
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# === Cloudflare R2 ===
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=gymstack-files
R2_PUBLIC_URL=https://files.mygymapp.in

# === Firebase (FCM) ===
FIREBASE_PROJECT_ID=gymstack
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@gymstack.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"

# === WATI (WhatsApp) ===
WATI_API_URL=https://live-server-XXXXX.wati.io
WATI_API_KEY=your-wati-api-key

# === MSG91 (SMS) ===
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=GYMSTK
MSG91_OTP_TEMPLATE_ID=your-template-id

# === App Config ===
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
PLATFORM_DOMAIN=mygymapp.in
