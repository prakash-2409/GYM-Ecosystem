generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Gym (White-label tenant) ──────────────────────────

model Gym {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(200)
  slug           String   @unique @db.VarChar(100)
  subdomain      String   @unique @db.VarChar(150)
  logoUrl        String?  @map("logo_url")
  primaryColor   String   @default("#2563EB") @map("primary_color") @db.VarChar(7)
  secondaryColor String   @default("#1E40AF") @map("secondary_color") @db.VarChar(7)
  ownerName      String   @map("owner_name") @db.VarChar(200)
  ownerPhone     String   @map("owner_phone") @db.VarChar(15)
  ownerEmail     String?  @map("owner_email") @db.VarChar(255)
  address        String?
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(100)
  pincode        String?  @db.VarChar(6)
  gstin          String?  @db.VarChar(15)
  isActive       Boolean  @default(true) @map("is_active")
  timezone       String   @default("Asia/Kolkata") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  users              User[]
  members            Member[]
  membershipPlans    MembershipPlan[]
  memberSubscriptions MemberSubscription[]
  checkIns           CheckIn[]
  payments           Payment[]
  workoutPlans       WorkoutPlan[]
  dietCharts         DietChart[]
  notificationsLog   NotificationLog[]
  saasSubscription   SaasSubscription?

  @@index([slug])
  @@map("gyms")
}

// ─── User (all roles) ──────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  gymId        String?   @map("gym_id") @db.Uuid
  role         String    @db.VarChar(20)
  phone        String    @db.VarChar(15)
  email        String?   @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(200)
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  fcmToken     String?   @map("fcm_token")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  gym                     Gym?                     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member                  Member?
  createdWorkoutPlans     WorkoutPlan[]             @relation("WorkoutPlanCreator")
  workoutAssignments      MemberWorkoutAssignment[] @relation("WorkoutAssigner")
  createdDietCharts       DietChart[]               @relation("DietChartCreator")
  dietAssignments         MemberDietAssignment[]    @relation("DietAssigner")
  recordedBodyStats       BodyStat[]                @relation("BodyStatRecorder")

  @@unique([phone, gymId])
  @@index([gymId, role])
  @@index([phone])
  @@map("users")
}

// ─── Member ────────────────────────────────────────────

model Member {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  gymId          String   @map("gym_id") @db.Uuid
  memberCode     String   @map("member_code") @db.VarChar(20)
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  gender         String?  @db.VarChar(10)
  emergencyPhone String?  @map("emergency_phone") @db.VarChar(15)
  bloodGroup     String?  @map("blood_group") @db.VarChar(5)
  joinedAt       DateTime @default(now()) @map("joined_at") @db.Date
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym                 Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  subscriptions       MemberSubscription[]
  checkIns            CheckIn[]
  payments            Payment[]
  workoutAssignments  MemberWorkoutAssignment[]
  dietAssignments     MemberDietAssignment[]
  bodyStats           BodyStat[]
  notificationsLog    NotificationLog[]

  @@unique([gymId, memberCode])
  @@index([gymId])
  @@map("members")
}

// ─── Membership Plans ──────────────────────────────────

model MembershipPlan {
  id           String   @id @default(uuid()) @db.Uuid
  gymId        String   @map("gym_id") @db.Uuid
  name         String   @db.VarChar(100)
  durationDays Int      @map("duration_days")
  price        Decimal  @db.Decimal(10, 2)
  gstPercent   Decimal  @default(18.00) @map("gst_percent") @db.Decimal(4, 2)
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  gym           Gym                  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  subscriptions MemberSubscription[]

  @@index([gymId])
  @@map("membership_plans")
}

// ─── Member Subscriptions ──────────────────────────────

model MemberSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  memberId   String   @map("member_id") @db.Uuid
  planId     String   @map("plan_id") @db.Uuid
  gymId      String   @map("gym_id") @db.Uuid
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  status     String   @default("active") @db.VarChar(20)
  amountPaid Decimal  @map("amount_paid") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  member   Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  plan     MembershipPlan @relation(fields: [planId], references: [id])
  gym      Gym            @relation(fields: [gymId], references: [id])
  payments Payment[]

  @@index([memberId])
  @@index([gymId, status])
  @@index([endDate])
  @@map("member_subscriptions")
}

// ─── Check-ins ─────────────────────────────────────────

model CheckIn {
  id          String   @id @default(uuid()) @db.Uuid
  memberId    String   @map("member_id") @db.Uuid
  gymId       String   @map("gym_id") @db.Uuid
  checkedInAt DateTime @default(now()) @map("checked_in_at") @db.Timestamptz()
  source      String   @default("kiosk") @db.VarChar(20)
  synced      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  gym    Gym    @relation(fields: [gymId], references: [id])

  @@index([memberId, checkedInAt(sort: Desc)])
  @@index([gymId, checkedInAt(sort: Desc)])
  @@map("check_ins")
}

// ─── Payments ──────────────────────────────────────────

model Payment {
  id                  String   @id @default(uuid()) @db.Uuid
  memberId            String   @map("member_id") @db.Uuid
  gymId               String   @map("gym_id") @db.Uuid
  subscriptionId      String?  @map("subscription_id") @db.Uuid
  amount              Decimal  @db.Decimal(10, 2)
  gstAmount           Decimal  @default(0) @map("gst_amount") @db.Decimal(10, 2)
  totalAmount         Decimal  @map("total_amount") @db.Decimal(10, 2)
  paymentMethod       String   @map("payment_method") @db.VarChar(20)
  paymentStatus       String   @default("completed") @map("payment_status") @db.VarChar(20)
  razorpayPaymentId   String?  @map("razorpay_payment_id") @db.VarChar(100)
  razorpayOrderId     String?  @map("razorpay_order_id") @db.VarChar(100)
  upiRef              String?  @map("upi_ref") @db.VarChar(100)
  invoiceNumber       String   @map("invoice_number") @db.VarChar(50)
  invoiceUrl          String?  @map("invoice_url")
  notes               String?
  paidAt              DateTime @default(now()) @map("paid_at") @db.Timestamptz()
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  member       Member              @relation(fields: [memberId], references: [id])
  gym          Gym                 @relation(fields: [gymId], references: [id])
  subscription MemberSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([memberId])
  @@index([gymId, paidAt(sort: Desc)])
  @@index([invoiceNumber])
  @@map("payments")
}

// ─── Exercises (master list) ───────────────────────────

model Exercise {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(200)
  nameHi      String? @map("name_hi") @db.VarChar(200)
  muscleGroup String  @map("muscle_group") @db.VarChar(50)
  equipment   String? @db.VarChar(100)
  description String?
  imageUrl    String? @map("image_url")
  videoUrl    String? @map("video_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  workoutPlanExercises WorkoutPlanExercise[]

  @@index([muscleGroup])
  @@map("exercises")
}

// ─── Workout Plans ─────────────────────────────────────

model WorkoutPlan {
  id          String   @id @default(uuid()) @db.Uuid
  gymId       String   @map("gym_id") @db.Uuid
  name        String   @db.VarChar(200)
  description String?
  createdBy   String?  @map("created_by") @db.Uuid
  isTemplate  Boolean  @default(false) @map("is_template")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  gym         Gym                       @relation(fields: [gymId], references: [id])
  creator     User?                     @relation("WorkoutPlanCreator", fields: [createdBy], references: [id])
  days        WorkoutPlanDay[]
  assignments MemberWorkoutAssignment[]

  @@index([gymId])
  @@map("workout_plans")
}

model WorkoutPlanDay {
  id            String @id @default(uuid()) @db.Uuid
  workoutPlanId String @map("workout_plan_id") @db.Uuid
  dayNumber     Int    @map("day_number")
  dayName       String? @map("day_name") @db.VarChar(50)
  sortOrder     Int    @default(0) @map("sort_order")

  workoutPlan WorkoutPlan           @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercises   WorkoutPlanExercise[]

  @@map("workout_plan_days")
}

model WorkoutPlanExercise {
  id          String  @id @default(uuid()) @db.Uuid
  planDayId   String  @map("plan_day_id") @db.Uuid
  exerciseId  String  @map("exercise_id") @db.Uuid
  sets        Int     @default(3)
  reps        String  @default("12") @db.VarChar(20)
  restSeconds Int     @default(60) @map("rest_seconds")
  notes       String?
  sortOrder   Int     @default(0) @map("sort_order")

  planDay  WorkoutPlanDay @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@map("workout_plan_exercises")
}

model MemberWorkoutAssignment {
  id            String   @id @default(uuid()) @db.Uuid
  memberId      String   @map("member_id") @db.Uuid
  workoutPlanId String   @map("workout_plan_id") @db.Uuid
  assignedBy    String?  @map("assigned_by") @db.Uuid
  assignedAt    DateTime @default(now()) @map("assigned_at") @db.Timestamptz()
  isActive      Boolean  @default(true) @map("is_active")

  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  assigner    User?       @relation("WorkoutAssigner", fields: [assignedBy], references: [id])

  @@index([memberId, isActive])
  @@map("member_workout_assignments")
}

// ─── Diet Charts ───────────────────────────────────────

model DietChart {
  id            String   @id @default(uuid()) @db.Uuid
  gymId         String   @map("gym_id") @db.Uuid
  name          String   @db.VarChar(200)
  description   String?
  totalCalories Int?     @map("total_calories")
  createdBy     String?  @map("created_by") @db.Uuid
  isTemplate    Boolean  @default(false) @map("is_template")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  gym         Gym                    @relation(fields: [gymId], references: [id])
  creator     User?                  @relation("DietChartCreator", fields: [createdBy], references: [id])
  meals       DietMeal[]
  assignments MemberDietAssignment[]

  @@index([gymId])
  @@map("diet_charts")
}

model DietMeal {
  id             String   @id @default(uuid()) @db.Uuid
  dietChartId    String   @map("diet_chart_id") @db.Uuid
  mealType       String   @map("meal_type") @db.VarChar(30)
  mealName       String   @map("meal_name") @db.VarChar(200)
  description    String?
  calories       Int?
  proteinG       Decimal? @map("protein_g") @db.Decimal(5, 1)
  carbsG         Decimal? @map("carbs_g") @db.Decimal(5, 1)
  fatG           Decimal? @map("fat_g") @db.Decimal(5, 1)
  timeSuggestion String?  @map("time_suggestion") @db.VarChar(20)
  sortOrder      Int      @default(0) @map("sort_order")

  dietChart DietChart @relation(fields: [dietChartId], references: [id], onDelete: Cascade)

  @@map("diet_meals")
}

model MemberDietAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  memberId    String   @map("member_id") @db.Uuid
  dietChartId String   @map("diet_chart_id") @db.Uuid
  assignedBy  String?  @map("assigned_by") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at") @db.Timestamptz()
  isActive    Boolean  @default(true) @map("is_active")

  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dietChart DietChart @relation(fields: [dietChartId], references: [id])
  assigner  User?     @relation("DietAssigner", fields: [assignedBy], references: [id])

  @@index([memberId, isActive])
  @@map("member_diet_assignments")
}

// ─── Body Stats ────────────────────────────────────────

model BodyStat {
  id          String   @id @default(uuid()) @db.Uuid
  memberId    String   @map("member_id") @db.Uuid
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Date
  weightKg    Decimal? @map("weight_kg") @db.Decimal(5, 1)
  heightCm    Decimal? @map("height_cm") @db.Decimal(5, 1)
  bodyFatPct  Decimal? @map("body_fat_pct") @db.Decimal(4, 1)
  chestCm     Decimal? @map("chest_cm") @db.Decimal(5, 1)
  waistCm     Decimal? @map("waist_cm") @db.Decimal(5, 1)
  hipsCm      Decimal? @map("hips_cm") @db.Decimal(5, 1)
  bicepCm     Decimal? @map("bicep_cm") @db.Decimal(5, 1)
  thighCm     Decimal? @map("thigh_cm") @db.Decimal(5, 1)
  notes       String?
  recordedBy  String?  @map("recorded_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  recorder User?  @relation("BodyStatRecorder", fields: [recordedBy], references: [id])

  @@index([memberId, recordedAt(sort: Desc)])
  @@map("body_stats")
}

// ─── Notification Log ──────────────────────────────────

model NotificationLog {
  id        String    @id @default(uuid()) @db.Uuid
  gymId     String    @map("gym_id") @db.Uuid
  memberId  String?   @map("member_id") @db.Uuid
  type      String    @db.VarChar(30)
  channel   String    @db.VarChar(20)
  status    String    @default("pending") @db.VarChar(20)
  title     String?   @db.VarChar(200)
  body      String?
  metadata  Json?
  sentAt    DateTime? @map("sent_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  gym    Gym     @relation(fields: [gymId], references: [id])
  member Member? @relation(fields: [memberId], references: [id])

  @@index([gymId, type])
  @@index([memberId])
  @@map("notifications_log")
}

// ─── SaaS Plans (platform billing) ────────────────────

model SaasPlan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  priceMonthly Decimal  @map("price_monthly") @db.Decimal(10, 2)
  maxMembers   Int?     @map("max_members")
  maxStaff     Int?     @map("max_staff")
  features     Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  subscriptions SaasSubscription[]

  @@map("saas_plans")
}

model SaasSubscription {
  id                     String    @id @default(uuid()) @db.Uuid
  gymId                  String    @unique @map("gym_id") @db.Uuid
  saasPlanId             String    @map("saas_plan_id") @db.Uuid
  status                 String    @default("trial") @db.VarChar(20)
  trialEndsAt            DateTime? @map("trial_ends_at") @db.Timestamptz()
  currentPeriodStart     DateTime? @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd       DateTime? @map("current_period_end") @db.Timestamptz()
  razorpaySubscriptionId String?   @map("razorpay_subscription_id") @db.VarChar(100)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  gym      Gym      @relation(fields: [gymId], references: [id])
  saasPlan SaasPlan @relation(fields: [saasPlanId], references: [id])

  @@index([status])
  @@map("saas_subscriptions")
}
