{
  "name": "gymstack",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "dotenv -- turbo dev",
    "build": "dotenv -- turbo build",
    "lint": "dotenv -- turbo lint",
    "db:generate": "dotenv -- turbo db:generate",
    "db:push": "dotenv -- turbo db:push",
    "db:seed": "dotenv -- turbo db:seed",
    "api:dev": "dotenv -- turbo dev --filter=api",
    "web:dev": "dotenv -- turbo dev --filter=web"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}